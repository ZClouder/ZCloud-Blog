---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
const nav = [
  { href: '/', label: '首页' },
  { href: '/posts', label: '文章' },
  { href: '/projects', label: '项目' },
  { href: '/friends', label: '友邻' },
  { href: '/about', label: '关于' },
];
const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 z-50 w-full border-b transition-all duration-300"
  data-transparent={transparent ? "true" : undefined}
  style="border-color: var(--color-border); background-color: color-mix(in srgb, var(--color-bg) 85%, transparent);"
>
  <div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a href="/" class="font-heading text-lg font-bold tracking-wide" style="color: var(--color-text);">
      流雲の宝藏
    </a>
    <nav class="flex items-center gap-6">
      {nav.map((item) => (
        <a
          href={item.href}
          class="nav-link text-sm transition-colors hover:opacity-70"
          style={`color: ${currentPath === item.href ? 'var(--color-accent)' : 'var(--color-text-muted)'}`}
        >
          {item.label}
        </a>
      ))}
      <button
        id="theme-toggle"
        type="button"
        aria-label="切换主题"
        class="flex h-8 w-8 items-center justify-center rounded-full border transition-colors hover:opacity-70"
        style="border-color: var(--color-border); color: var(--color-text);"
      >
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<style>
  #site-header[data-transparent="true"] {
    background-color: transparent !important;
    border-color: transparent !important;
    backdrop-filter: none;
  }
  #site-header[data-transparent="true"] a,
  #site-header[data-transparent="true"] button {
    color: white !important;
    border-color: rgba(255,255,255,0.3) !important;
  }
  #site-header:not([data-transparent="true"]) {
    backdrop-filter: blur(12px);
  }
</style>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    const sun = document.getElementById('icon-sun');
    const moon = document.getElementById('icon-moon');

    function syncIcons() {
      const isDark = document.documentElement.dataset.theme === 'dark';
      sun?.classList.toggle('hidden', isDark);
      moon?.classList.toggle('hidden', !isDark);
    }
    syncIcons();

    btn?.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
      syncIcons();
    });

    // Transparent header: observe hero visibility
    const header = document.getElementById('site-header');
    const hero = document.getElementById('hero');
    if (header && hero && header.dataset.transparent === 'true') {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            header.dataset.transparent = 'true';
          } else {
            header.dataset.transparent = 'false';
          }
        },
        { threshold: 0, rootMargin: '-64px 0px 0px 0px' }
      );
      observer.observe(hero);
    }
  })();
</script>
